{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Expires", "value": "Thu, 31 Dec 2026 23:59:59 GMT" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/(.*\\.js|.*\\.mjs|.*\\.cjs)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Expires", "value": "Thu, 31 Dec 2026 23:59:59 GMT" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/(.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Expires", "value": "Thu, 31 Dec 2026 23:59:59 GMT" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/(.*\\.woff|.*\\.woff2|.*\\.ttf|.*\\.otf|.*\\.eot)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Expires", "value": "Thu, 31 Dec 2026 23:59:59 GMT" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/(.*\\.webp|.*\\.jpg|.*\\.jpeg|.*\\.png|.*\\.ico|.*\\.svg|.*\\.gif|.*\\.avif)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" },
        { "key": "Expires", "value": "Thu, 21 Apr 2026 00:00:00 GMT" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/(.*\\.json|.*\\.xml|.*\\.txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=600" },
        { "key": "Expires", "value": "Sun, 22 Mar 2026 02:00:00 GMT" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Vary", "value": "Accept-Encoding" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Expires", "value": "Thu, 22 Mar 2026 13:30:00 GMT" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/cameras", "destination": "/cameras/index.html" },
    { "source": "/phone-systems", "destination": "/phone-systems/index.html" },
    {
      "source": "/((?!assets|fonts|digital-signage|cameras|phone-systems|favicon|robots\\.txt|sitemap\\.xml|.*\\.(js|css|webp|jpg|jpeg|png|svg|ico|gif|woff|woff2|ttf|otf|eot|json|xml|txt|map|br|gz)).*)",
      "destination": "/index.html"
    }
  ]
}
