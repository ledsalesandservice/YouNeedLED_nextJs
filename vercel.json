{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "redirects": [
    { "source": "/cameras", "destination": "/services/video-surveillance", "permanent": false },
    { "source": "/phone-systems", "destination": "/services/voip", "permanent": false }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
