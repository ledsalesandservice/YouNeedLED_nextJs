{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.png|.*\\.webp|.*\\.jpg|.*\\.jpeg|.*\\.ico|.*\\.svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/cameras", "destination": "/cameras/index.html" },
    { "source": "/phone-systems", "destination": "/phone-systems/index.html" },
    { "source": "/((?!cameras|phone-systems).*)", "destination": "/index.html" }
  ]
}
