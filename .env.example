# Email — required for contact form and port-out request form
# Use a Gmail address with an App Password (myaccount.google.com/apppasswords)
SMTP_USER=youneedled@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Optional: override the recipient address (defaults to info@youneedled.com)
CONTACT_TO_EMAIL=info@youneedled.com

# ─── Manus CRM → FreshBooks Invoice Sync (/api/sync-invoices) ─────────────────

# Manus CRM
MANUS_API_KEY=your-manus-api-key
MANUS_BASE_URL=https://ledservice.manus.space/api/sync

# FreshBooks OAuth2
# To get these: FreshBooks Dashboard → My Apps → create an app → note client ID + secret
# Then complete the OAuth flow once to get a refresh token (long-lived)
FRESHBOOKS_CLIENT_ID=your-freshbooks-client-id
FRESHBOOKS_CLIENT_SECRET=your-freshbooks-client-secret
FRESHBOOKS_REFRESH_TOKEN=your-freshbooks-refresh-token
# Account ID: visible in FreshBooks URL — app.freshbooks.com/dashboard URL shows /account/XXXXXXX/
FRESHBOOKS_ACCOUNT_ID=your-freshbooks-account-id

# Shared secret to prevent unauthorized sync triggers (generate: openssl rand -hex 32)
SYNC_SECRET=your-sync-secret

# ─── Telegram Bot (scripts/telegram-bot.ts) ───────────────────────────────────
# Get token: Telegram → search @BotFather → /newbot → follow prompts → copy token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Fill in after running /start once — the bot will tell you your chat_id
TELEGRAM_ALLOWED_CHAT_ID=your-telegram-chat-id
# Paperclip connection (so the bot can post comments and read task status)
PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_COMPANY_ID=d6aa9d19-85bc-452c-98ca-d5a99d4ee058
PAPERCLIP_API_KEY=your-paperclip-api-key
